{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": false,
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "monsqlize": [
        "./dist/types/index.d.ts"
      ]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.mts",
    "examples/**/*.ts",
    "index.d.ts",
    "dist/types/**/*.d.ts",
    "types/**/*.d.ts",
    "test/types/**/*.d.ts"
  ]
}

