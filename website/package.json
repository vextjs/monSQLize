{
  "name": "monsqlize-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rspress dev",
    "build": "rspress build",
    "preview": "rspress preview",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "check:links": "node ../scripts/validation/check-site-links.cjs",
    "check:budgets": "node ../scripts/validation/check-site-budgets.cjs",
    "check:browser": "node scripts/check-browser.cjs",
    "check:audit": "npm audit",
    "verify": "npm run type-check && npm run build && npm run check:links && npm run check:budgets && npm run check:browser && npm run check:audit"
  },
  "dependencies": {
    "@rspress/core": "2.0.17",
    "@rspress/plugin-sitemap": "2.0.17"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "axe-core": "4.12.1",
    "playwright": "1.61.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3"
  }
}
